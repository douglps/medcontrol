# Melhoria docs/melhorias-integracao-back-front.md, Sequência E: este
# arquivo listava DB_USER/DB_PASSWORD, mas src/database/database.js usa
# APP_DB_USER/APP_DB_PASSWORD (role de aplicação, DML apenas) e
# MIGRATOR_DB_USER/MIGRATOR_DB_PASSWORD (role usada só pelo script
# `npm run sync`, com permissão de criar/alterar tabelas) — Princípio do
# Menor Privilégio. Corrigido para refletir as variáveis reais.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medcontrol
APP_DB_USER=medcontrol_app
APP_DB_PASSWORD=troque_esta_senha
MIGRATOR_DB_USER=medcontrol_migrator
MIGRATOR_DB_PASSWORD=troque_esta_senha_tambem
EXPRESS_PORT=3000
